{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "0.0.0",
  "identifier": "cc.yeetdesigns.nexus",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build:client",
    "devUrl": "http://localhost:19274",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.insforge.com https://nexuschat.yeetdesigns.cc wss: ws:; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxRDEwNThENzU0RjQ2REYKUldUZlJrOTFqUVhSd1gwa2RpcnVFdlEvMHU3QzhucFlYM1dUeElRcUczYm1rZWdTdVZVOUM2QzcK",
      "endpoints": [
        "https://raw.githubusercontent.com/DAREALYTYGRUNN1NGARK456/nexus-chat/main/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}