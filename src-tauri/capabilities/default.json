{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capabilities/desktop-schema.json",
  "identifier": "default",
  "description": "Capability granted to the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "process:exit",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "updater:allow-download-and-install"
  ]
}
